# --- Zero-cost defaults: everything below works with no paid services ---

# Database: SQLite by default (no Docker needed). For Postgres+pgvector via docker-compose:
# DATABASE_URL=postgresql+asyncpg://career:career@localhost:5432/career
DATABASE_URL=sqlite+aiosqlite:///./career.db

# Redis cache (optional; in-memory fallback used when unreachable)
REDIS_URL=redis://localhost:6379/0

# LLM: local Ollama (free). Pull a model first: `ollama pull qwen2.5:7b`
LLM_MODEL=ollama/qwen2.5:7b
LLM_API_BASE=http://localhost:11434

# Optional paid providers (leave empty to stay 100% free)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional GitHub token (raises API rate limit from 60 to 5000 req/h; still free)
GITHUB_TOKEN=

# Auth
JWT_SECRET=change-me-in-production
